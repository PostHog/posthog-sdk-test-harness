#!/bin/bash
set -e

# Run SDK adapter tests using Docker Compose

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

cd "$PROJECT_ROOT"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

usage() {
    cat << EOF
Usage: bin/test [OPTIONS]

Run SDK adapter tests using Docker Compose.

OPTIONS:
    --adapter DIR         Path to adapter directory (default: examples/minimal_adapter)
    --concurrency N       Number of tests to run in parallel (requires parallel-capable adapter)
    --build               Force rebuild of containers
    --down                Stop and remove containers after test
    --help                Show this help message

EXAMPLES:
    # Test the minimal adapter (sequential)
    bin/test

    # Test the parallel adapter with concurrency
    bin/test --adapter examples/parallel_adapter --concurrency 4

    # Rebuild and test
    bin/test --build

    # Test and cleanup
    bin/test --down

EOF
}

# Default values
ADAPTER_DIR="examples/minimal_adapter"
CONCURRENCY=""
BUILD_FLAG=""
DOWN_FLAG=""

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --adapter)
            ADAPTER_DIR="$2"
            shift 2
            ;;
        --concurrency)
            CONCURRENCY="$2"
            shift 2
            ;;
        --build)
            BUILD_FLAG="--build"
            shift
            ;;
        --down)
            DOWN_FLAG="yes"
            shift
            ;;
        --help)
            usage
            exit 0
            ;;
        *)
            echo -e "${RED}Unknown option: $1${NC}"
            usage
            exit 1
            ;;
    esac
done

echo "=========================================="
echo "  PostHog SDK Test Harness (Docker)"
echo "=========================================="
echo ""
echo "Adapter: $ADAPTER_DIR"
if [ -n "$CONCURRENCY" ]; then
    echo "Concurrency: $CONCURRENCY"
fi
echo ""

export ADAPTER_DIR

# Export concurrency for docker-compose environment variable substitution
if [ -n "$CONCURRENCY" ]; then
    export CONCURRENCY
fi

# Build and run using docker compose up (required for DNS resolution between containers)
echo -e "${YELLOW}Building and starting containers...${NC}"
set +e
docker compose up --abort-on-container-exit $BUILD_FLAG
EXIT_CODE=$?
set -e

# Cleanup if requested
if [ "$DOWN_FLAG" = "yes" ]; then
    echo ""
    echo -e "${YELLOW}Cleaning up containers...${NC}"
    docker compose down
fi

# Report results
echo ""
if [ $EXIT_CODE -eq 0 ]; then
    echo -e "${GREEN}✓ Tests passed!${NC}"
else
    echo -e "${RED}✗ Tests failed${NC}"
fi

exit $EXIT_CODE
